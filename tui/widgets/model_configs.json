{
    "models": {
        "VAE": {
            "params": [
                {"id": "init-peptide", "label": "Peptide sequence:", "type": "input", "placeholder": "RWRFR", "coerce": "String"}
            ]
        },

        "CVAE": {
            "params": [
                {"id": "init-peptide", "label": "Peptide sequence:", "type": "input", "placeholder": "RWRFR", "coerce": "String"},
                {"id": "hydrophobicity", "label": "Hydrophobicity:", "type": "input", "placeholder": "0.5", "coerce": "float"},
                {"id": "charge", "label": "Charge:", "type": "input", "placeholder": "1", "coerce": "int"},
                {"id": "length", "label": "Length:", "type": "input", "placeholder": "10", "coerce": "int"},
                {"id": "target-property", "label": "Target Property:", "type": "select", "options": ["hydrophobicity", "charge", "length"]},
                {"id": "LogP", "label": "LogP:", "type": "input", "placeholder": "0.5", "coerce": "float"}
            ],
            "hyperparameters": [
                {"id": "latent-dim", "label": "Latent Dimension:", "type": "input", "placeholder": "20", "coerce": "int"},
                {"id": "beta", "label": "Beta:", "type": "input", "placeholder": "1.0", "coerce": "float"},
                {"id": "continuous-learning", "label": "Continuous Learning:", "type": "select", "options": ["enabled", "disabled"]}
            ]
        },
        "GAN": {
            "params": [
                {"id": "param-noise", "label": "Noise Level:", "type": "input", "placeholder": "0.1", "coerce": "float"}
            ]
        },
        "LLM": {
            "params": [
                {"id": "param-temp", "label": "Temperature:", "type": "input", "placeholder": "0.7", "coerce": "float"},
                {"id": "param-mode", "label": "Sampling:",     "type": "select", "options": ["top-k", "top-p", "greedy"]}
            ]
        }
    },
    "bio_models": {
        "Bert-AMP" : "Bert-AMP",
        "LSTM-AMP" : "LSTM-AMP",
        "Transformer-AMP" : "Transformer-AMP"
    }
}